<Window x:Class="SistemaDeVenta.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Width="900"
        Height="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Grid>

        <!-- ===================== COLUMNAS RESPONSIVAS ===================== -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.30*" MinWidth="300"/>
            <ColumnDefinition Width="0.70*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== PANEL IZQUIERDO (AZUL) ===================== -->
        <Grid Grid.Column="0" Background="#007BFF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/Iconos/Tienda.png"
                       Width="120"
                       Margin="0 0 0 20"/>

                <TextBlock Text="Sistema de Venta"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ===================== PANEL DERECHO (FORMULARIO) ===================== -->
        <Grid Grid.Column="1" Background="#F2F2F2">

            <Grid.Resources>

                <!-- BOTÓN MODERNO -->
                <Style x:Key="ModernButton" TargetType="Button">
                    <Setter Property="Background" Value="#FF007BFF"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="3"/>
                    <Setter Property="Width" Value="120"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#EAEAEA"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#D5D5D5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- TEXTBOX ESTILO WEB (línea inferior) -->
                <Style x:Key="WebTextBox" TargetType="TextBox">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Margin" Value="0,0,0,25"/>
                    <Setter Property="Padding" Value="5,2"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#999"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TextBox">
                                <Border x:Name="border"
                                        Background="Transparent"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="#4A90E2"/>
                                        <Setter TargetName="border" Property="BorderThickness" Value="0,0,0,2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- PASSWORD BOX ESTILO WEB (línea inferior) -->
                <Style x:Key="WebPasswordBox" TargetType="PasswordBox">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Margin" Value="0,0,0,25"/>
                    <Setter Property="Padding" Value="5,2"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#999"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="PasswordBox">
                                <Border x:Name="border"
                                        Background="Transparent"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="#4A90E2"/>
                                        <Setter TargetName="border" Property="BorderThickness" Value="0,0,0,2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

            </Grid.Resources>

            <!-- ===================== FORMULARIO ===================== -->
            <StackPanel Width="350" VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="Iniciar Sesión"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#333"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <!-- Usuario -->
                <TextBlock Text="Nombre de Usuario" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsuario"
                         Style="{StaticResource WebTextBox}"
                         KeyDown="txtUsuario_KeyDown"/>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña" FontSize="14" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtClave"
                             Style="{StaticResource WebPasswordBox}"
                             KeyDown="txtClave_KeyDown"/>

                <!-- Botón Entrar -->
                <Button Content="Entrar"
                        Style="{StaticResource ModernButton}"
                        Width="350"
                        Height="30"
                        Click="Aceptar_Click"/>
                <Button Content="Salir" Width="100" Height="35" Click="Salir_Click" Background="#FF4C4C" Foreground="White"/>
            </StackPanel>

        </Grid>

    </Grid>

</Window>
