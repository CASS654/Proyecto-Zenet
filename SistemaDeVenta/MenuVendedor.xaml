<Window x:Class="SistemaDeVenta.MenuVendedor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SistemaDeVenta"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Title="Sistema de Ventas" Height="600" Width="1000">

    <Grid>

        <!-- FILAS DEL GRID -->
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <!-- Header -->
            <RowDefinition Height="60"/>
            <!-- Menú -->
            <RowDefinition Height="*"/>
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Background="#007BFF" Grid.Row="0">
            <TextBlock Text="Sistema de Ventas"
                       Foreground="White"
                       FontSize="32"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0"/>

            <!-- BOTÓN CERRAR SESIÓN -->
            <Button Width="120"
                    Height="40"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,20,0"
                    Background="#FF4C4C"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CerrarSesion_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="Iconos/Salir.png" Width="20" Height="20"/>
                    <TextBlock Text="Cerrar Sesión" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- MENÚ -->
        <StackPanel Orientation="Horizontal"
                    Grid.Row="1"
                    Background="White"
                    Height="60">

            <!-- VENTAS -->
            <Button Width="140"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Ventas_Click">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <Image Source="Iconos/Etiqueta.png" Width="24" Height="24"/>
                    <TextBlock Text="Ventas"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               FontSize="18"/>
                </StackPanel>
            </Button>

        </StackPanel>

        <!-- CONTENEDOR DE VISTAS -->
        <ContentControl x:Name="Contenedor"
                        Grid.Row="2"
                        Background="#F2F2F2"/>
    </Grid>
</Window>
