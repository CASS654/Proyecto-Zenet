<Window x:Class="SistemaDeVenta.AdministradorWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="POS Admin"
            WindowStartupLocation="CenterScreen"
            Background="#0B0F14"
            ResizeMode="NoResize"
            WindowStyle="None"
            WindowState="Maximized"
            Focusable="True">

    <!-- ================= RECURSOS ================= -->

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#EF1C3A"/>
        <SolidColorBrush x:Key="Dark1" Color="#0B0F14"/>
        <SolidColorBrush x:Key="Dark2" Color="#141A22"/>
        <SolidColorBrush x:Key="Dark3" Color="#1C232D"/>
        <SolidColorBrush x:Key="Border" Color="#2B3442"/>
        <SolidColorBrush x:Key="TextGray" Color="#8A94A6"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FF334D"/>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8A94A6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="15,0">

                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                            Property="Background"
                                            Value="#1E2632"/>
                                <Setter Property="Foreground"
                                            Value="White"/>
                            </Trigger>

                            <!-- MODO COMPACTO -->
                            <DataTrigger Binding="{Binding ActualWidth, ElementName=Sidebar}"
                                             Value="75">
                                <Setter Property="HorizontalContentAlignment"
                                            Value="Center"/>
                                <Setter TargetName="border"
                                            Property="Padding"
                                            Value="0"/>
                            </DataTrigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ================= PRINCIPAL ================= -->

    <Grid>

        <Grid.ColumnDefinitions>
            <!-- AUTO AJUSTABLE -->
            <ColumnDefinition x:Name="SidebarColumn" Width="240" MinWidth="75"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= SIDEBAR ================= -->

        <Border x:Name="Sidebar"
                    Grid.Column="0"     
                    Background="{StaticResource Dark2}">

            <DockPanel Margin="12">

                <Border x:Name="ProfileSection"
        DockPanel.Dock="Bottom"
        Background="#101620"
        CornerRadius="10"
        Padding="10">

                    <Grid>
                        <!-- Avatar solo (modo colapsado) -->
                        <Grid x:Name="ProfileAvatar"
                              Width="30"
                              Height="30"
                              HorizontalAlignment="Center"
                              Visibility="Collapsed">

                            <Ellipse Fill="{StaticResource Primary}"/>

                            <TextBlock Text="{Binding Text, ElementName=TxtInicial}"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        </Grid>

                        <!-- Perfil completo -->
                        <StackPanel x:Name="ProfileFull"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="10,0,0,0">

                            <Grid Width="30" Height="30">
                                <Ellipse Fill="{StaticResource Primary}"/>

                                <TextBlock x:Name="TxtInicial"
                           Text="A"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Margin="8,0">
                                <TextBlock x:Name="TxtNombreUsuario"
                           Text="Admin"
                           Foreground="White"
                           FontWeight="SemiBold"/>

                                <TextBlock Text="Administrador"
                           Foreground="{StaticResource TextGray}"
                           FontSize="11"/>
                            </StackPanel>

                        </StackPanel>

                    </Grid>
                </Border>



                <!-- MENU -->
                <StackPanel x:Name="MenuPanel">

                    <!-- LOGO + BOTÓN AJUSTABLE -->
                    <Grid x:Name="HeaderSection" Margin="0,10,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo Container (Modo Expandido) -->
                        <StackPanel x:Name="LogoContainer"
                                        Grid.Column="0"
                                        Grid.Row="0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                            <Border Width="32"
                                        Height="32"
                                        Background="{StaticResource Primary}"
                                        CornerRadius="6"
                                        ClipToBounds="True">

                                <Grid>
                                    <Image Source="/SistemaDeVenta;component/Iconos/Logo/logoB.png"
                                        Stretch="Uniform" Margin="1,2,1,2">
                                        <Image.Clip>
                                            <RectangleGeometry Rect="0,0,28,28" RadiusX="6" RadiusY="6"/>
                                        </Image.Clip>
                                    </Image>
                                </Grid>

                            </Border>

                            <TextBlock x:Name="LogoText"
                                           Text=" POS Admin"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- Logo solo centrado (Modo Colapsado) -->
                        <Border x:Name="LogoCollapsed"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Grid.Row="0"
                                    Width="32"
                                    Height="32"
                                    Background="{StaticResource Primary}"
                                    CornerRadius="6"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <Grid>
                                <Image Source="/SistemaDeVenta;component/Iconos/Logo/logoB.png"
                                       Stretch="Uniform" Margin="1,2,1,2">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,28,28" RadiusX="6" RadiusY="6"/>
                                    </Image.Clip>
                                </Image>
                            </Grid>

                        </Border>

                        <!-- Botón menú (empieza a la derecha del logo - Modo Expandido) -->
                        <Button x:Name="MenuToggleButton"
                                    Grid.Column="1"
                                    Grid.Row="0"
                                    Width="32"
                                    Height="32"
                                    Content="☰"
                                    FontSize="16"
                                    Background="Transparent"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Click="ToggleSidebar_Click"/>

                        <!-- Botón menú abajo (Modo Colapsado) -->
                        <Button x:Name="MenuToggleButtonCollapsed"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Grid.Row="1"
                                    Width="32"
                                    Height="32"
                                    Content="☰"
                                    FontSize="16"
                                    Background="Transparent"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,20,0,0"
                                    Visibility="Collapsed"
                                    Click="ToggleSidebar_Click"/>
                    </Grid>

                    <!-- BOTONES -->

                    <Button Style="{StaticResource MenuButton}" Click="Button_Click_1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="18" Width="30" TextAlignment="Center"/>
                            <TextBlock x:Name="TxtDashboard" Text="Dashboard" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛒" FontSize="18" Width="30" TextAlignment="Center"/>
                            <TextBlock x:Name="TxtSales" Text="Ventas" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" Click="Button_Click_4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="18" Width="30" TextAlignment="Center"/>
                            <TextBlock x:Name="TxtInventory" Text="Inventario" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" Click="Button_Click_2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="18" Width="30" TextAlignment="Center"/>
                            <TextBlock x:Name="TxtEmployees" Text="Usuarios" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" Click="Button_Click_3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="18" Width="30" TextAlignment="Center"/>
                            <TextBlock x:Name="TxtCustomers" Text="Provedores" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" Click="Button_Click_5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚚" FontSize="18" Width="30" TextAlignment="Center"/>
                            <TextBlock x:Name="TxtSuppliers" Text="Suministros" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </DockPanel>

        </Border>

        <!-- ================= PANEL DERECHO (INTACTO) ================= -->

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="119*"/>
                <ColumnDefinition Width="352*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>


            <!-- HEADER -->

            <Border Grid.Row="0"
                Background="{StaticResource Dark2}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1" Grid.ColumnSpan="2">

                <Grid Margin="24">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <TextBlock x:Name="TxtTitulo"
                           Text="Inicio"
                           Foreground="White"
                           FontSize="26"
                           VerticalAlignment="Bottom" MouseLeftButtonDown="TextBlock_MouseLeftButtonDown" Margin="0,0,0,3"/>


                    <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                        <Border Width="240"
                            Height="34"
                            Background="#101620"
                            CornerRadius="7"
                            Margin="0,0,14,0" HorizontalAlignment="Center" VerticalAlignment="Top">

                            <TextBox Text=" Search..."
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        </Border>


                        <TextBlock Text="🔔"
                               FontSize="18"
                               Margin="0,0,14,0"
                               Foreground="White"
                               TextAlignment="Center"
                               />


                        <Border BorderBrush="{StaticResource AccentRed}" BorderThickness="1" Background="#20FF334D" CornerRadius="8" Padding="15,8"  MouseLeftButtonDown="Logout_Click"  Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource AccentRed}" CornerRadius="4" Padding="4,1" Margin="0,0,8,0">
                                    <TextBlock Text="ESC" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="LOGOUT ➔" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                </Grid>

            </Border>


            <!-- CONTENIDO -->

            <Border Grid.Row="1"
                Background="{StaticResource Dark1}"
                Padding="0"  Grid.ColumnSpan="2">

                <Border Background="{StaticResource Dark3}"
                        CornerRadius="0" BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        Padding="0"    Margin="0">
                    <ContentControl x:Name="MainContent" 
                        HorizontalContentAlignment="Stretch" 
                        VerticalContentAlignment="Stretch"/>
                </Border>
            </Border>


            <!-- FOOTER -->

            <Border Grid.Row="2"
                Background="{StaticResource Dark2}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0" Grid.ColumnSpan="2">

                <Grid Margin="20"/>

            </Border>

        </Grid>

    </Grid>

</Window>
