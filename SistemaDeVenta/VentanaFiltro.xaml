<Window x:Class="SistemaDeVentaPrueba.VentanaFiltro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filtros" 
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelDark" Color="#1C2132"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2D3348"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FF334D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B92A5"/>
    </Window.Resources>

    <Border x:Name="FilterPanel" 
            Width="320" 
            Background="{StaticResource PanelDark}" 
            BorderBrush="{StaticResource BorderDark}" 
            BorderThickness="1" 
            CornerRadius="10" 
            Padding="20"
            Margin="5">
        <StackPanel>
            <Grid Margin="0,0,0,15">
                <TextBlock Text="CATEGORIES" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="12"/>
                <TextBlock Text="[ENTER TO SELECT]" Foreground="{StaticResource TextSecondary}" FontSize="10" HorizontalAlignment="Right"/>
            </Grid>

            <Border Background="#20FF334D" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                <Grid>
                    <TextBlock Text="All Products" Foreground="{StaticResource AccentRed}" FontWeight="SemiBold"/>
                    <TextBlock Text="✓" Foreground="{StaticResource AccentRed}" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <TextBlock Text="Electronics" Foreground="{StaticResource TextPrimary}" Margin="12,5" FontSize="14"/>
            <TextBlock Text="Gaming Gear" Foreground="{StaticResource TextPrimary}" Margin="12,5" FontSize="14"/>
            <TextBlock Text="Peripherals" Foreground="{StaticResource TextPrimary}" Margin="12,5,12,15" FontSize="14"/>

            <Separator Background="{StaticResource BorderDark}" Margin="0,5,0,15"/>

            <TextBlock Text="AVAILABILITY" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>
            <UniformGrid Columns="2" Margin="0,0,0,15">
                <Border Background="{StaticResource BorderDark}" CornerRadius="6" Padding="10" Margin="0,0,5,0">
                    <TextBlock Text="In Stock" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Border Background="Transparent" CornerRadius="6" Padding="10" Margin="5,0,0,0">
                    <TextBlock Text="Out of Stock" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                </Border>
            </UniformGrid>

            <Separator Background="{StaticResource BorderDark}" Margin="0,5,0,15"/>

            <TextBlock Text="SORT BY" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>
            <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="5">
                <Grid>
                    <TextBlock Text="Relevance" Foreground="{StaticResource TextPrimary}" FontSize="14"/>
                    <TextBlock Text="▼" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                </Grid>
            </Border>

            <Grid>
                <TextBlock Text="Reset all" Foreground="{StaticResource TextSecondary}" TextDecorations="Underline" Cursor="Hand"/>
                <TextBlock Text="Press [ESC] to close" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" FontSize="11"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>