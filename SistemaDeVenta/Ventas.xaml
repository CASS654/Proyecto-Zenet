<UserControl x:Class="SistemaDeVenta.Ventas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <UserControl.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ENCABEZADO AZUL -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="97*"/>
            <RowDefinition Height="247*"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <TextBlock Text="Registrar Venta"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>


        <!-- ========== FILA 1: INFORMACIÓN VENTA + INFORMACIÓN CLIENTE ======== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- INFORMACIÓN VENTA -->

            <!-- INFORMACIÓN CLIENTE -->
        </Grid>


        <!-- ========== FILA 2: INFORMACIÓN DE PRODUCTO ========== -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,5">
            <Grid Margin="10" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <!-- Botón buscar fijo -->
                    <ColumnDefinition Width="2*"/>
                    <!-- Producto flexible -->
                    <ColumnDefinition Width="1.2*"/>
                    <!-- Precio flexible -->
                    <ColumnDefinition Width="1.2*"/>
                    <!-- Stock flexible -->
                    <ColumnDefinition Width="1*"/>
                    <!-- Cantidad -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Botón agregar -->
                </Grid.ColumnDefinitions>

                <!-- Botón Buscar -->
                <Button Grid.Column="0" Content="🔍"
                Width="40"
                Click="Button_Click" Margin="5,27,5,0" Height="28" VerticalAlignment="Top"/>

                <!-- Producto -->
                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Producto:"/>
                    <TextBox x:Name="txtProducto" Height="28"
                     Margin="0,5,0,0" IsReadOnly="True"/>
                </StackPanel>

                <!-- Precio -->
                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="Precio:"/>
                    <TextBox x:Name="txtPrecio" Height="28"
                     Margin="0,5,0,0" IsReadOnly="True"/>
                </StackPanel>

                <!-- Stock -->
                <StackPanel Grid.Column="3" Margin="5">
                    <TextBlock Text="Stock:"/>
                    <TextBox x:Name="txtStock" Height="28"
                     Margin="0,5,0,0" IsReadOnly="True"/>
                </StackPanel>

                <!-- Cantidad -->
                <StackPanel Grid.Column="4" Margin="5">
                    <TextBlock Text="Cantidad:"/>
                    <TextBox x:Name="txtCantidad" Height="28"
                     Margin="0,5,0,0"
                     Text="1" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <!-- Botón Agregar -->
                <Button Grid.Column="5"
                Content="Agregar"
                Background="#28A745" Foreground="White"
                FontWeight="Bold"
                HorizontalAlignment="Left"
                Click="Button_Click_1"
                Margin="10,27,0,0"
                Height="28" VerticalAlignment="Top"/>
            </Grid>
        </Border>



        <!-- ========== FILA 3: TABLA + PANEL DERECHA ======== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- TABLA -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,10,0">
                <DataGrid x:Name="TablaVentas"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="35">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="200"/>
                        <DataGridTextColumn Header="Precio" Binding="{Binding PrecioVenta }" Width="100"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                        <DataGridTextColumn Header="Sub Total" Binding="{Binding Subtotal}" Width="100"/>
                        <DataGridTemplateColumn Header="Eliminar" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑" Width="40" Height="28" Background="#DC3545" Foreground="White"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                </DataGrid>
            </Border>

            <!-- PANEL DERECHA -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">

                <TextBlock Text="Total a Pagar:" FontWeight="Bold"  />

                <TextBox x:Name="txtTotal" Height="28" Margin="0,5,0,15" IsReadOnly="True"/>

                <TextBlock Text="Paga con:" FontWeight="Bold"/>
                <TextBox x:Name="txtPagaCon" Height="28" Margin="0,5,0,15" TextChanged="txtPagaCon_TextChanged"/>

                <TextBlock Text="Cambio:" FontWeight="Bold"/>
                <TextBox x:Name="txtCambio" Height="28" Margin="0,5,0,25" IsReadOnly="True"/>

                <Button Content="Crear Venta"
                        Background="#007BFF"
                        Foreground="White"
                        Height="45"
                        FontWeight="Bold" Click="Button_Click_2"/>
            </StackPanel>

        </Grid>

    </Grid>
</UserControl>
