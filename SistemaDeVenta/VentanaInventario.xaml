<UserControl x:Class="SistemaDeVenta.VentanaInventario"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1300"
             Background="#121624" FontFamily="Segoe UI">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#121624"/>
        <SolidColorBrush x:Key="PanelDark" Color="#1C2132"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2D3348"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FF334D"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#2ECC71"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#E67E22"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B92A5"/>

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,20">
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Total Products" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="1,284" Foreground="{StaticResource TextPrimary}" FontSize="40" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="+2.4%" Foreground="{StaticResource SuccessGreen}" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Text="📋" FontSize="20"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Low Stock Alerts" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="12" Foreground="{StaticResource TextPrimary}" FontSize="40" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="Requires Action" Foreground="{StaticResource WarningOrange}" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Text="⚠️" FontSize="20"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Out of Stock Items" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="5" Foreground="{StaticResource TextPrimary}" FontSize="40" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="Critical" Foreground="{StaticResource AccentRed}" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Text="🚫" FontSize="20"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <Border Grid.Row="1" Background="{StaticResource PanelDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" 
                         FontSize="16" Margin="10,0" VerticalAlignment="Center" 
                         Text="Search products by name, SKU or ID..."/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                    <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="1" Background="{StaticResource PanelDark}" CornerRadius="8" Padding="15,10" Margin="0,0,10,0">
                        <TextBlock Text="Filters" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <Border BorderBrush="{StaticResource BorderDark}" BorderThickness="1" Background="{StaticResource PanelDark}" CornerRadius="8" Padding="10">
                        <TextBlock Text="🖨️" FontSize="16"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource PanelDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ID" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Nombre del Producto" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Categoria" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" />
                        <TextBlock Grid.Column="3" Text="Cantidad del Producto" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="Precio de Compra" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="Precio de Venta" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="6" Text="Disponibilidad" Foreground="#8B92A5"/>
                        <TextBlock Grid.Column="7" Text="Acciones" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="{StaticResource BorderDark}" Margin="0"/>

                    <ItemsControl x:Name="ItemsProductos" Grid.Row="1">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="20,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                           Text="{Binding IdProducto}" 
                           Foreground="#8B92A5"/>

                                    <TextBlock Grid.Column="1" 
                           Text="{Binding Nombre}" 
                           Foreground="White"
                           FontWeight="Bold"/>

                                    <TextBlock Grid.Column="2" 
                           Text="{Binding Categoria}" 
                           Foreground="#8B92A5"/>

                                    <StackPanel Grid.Column="3" Orientation="Horizontal">

                                        <Border Width="60" Height="6" CornerRadius="3" VerticalAlignment="Center">
                                            <Border Width="60" Height="6"  Background="{Binding ColorStock}" CornerRadius="3"/>
      
                                        </Border>

                                        <TextBlock Text="{Binding EstadoStock}" 
                                           Margin="10,0,0,0"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                        />
            
                                    </StackPanel>

                                    <TextBlock Grid.Column="4" 
                           Text="{Binding PrecioCompra}" 
                           Foreground="White"/>

                                    <TextBlock Grid.Column="5" 
                           Text="{Binding PrecioVenta}" 
                           Foreground="White"/>
                                    <TextBlock Grid.Column="6" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Disponible"/>
                                                <Setter Property="Foreground" Value="Green"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Disponible}" Value="False">
                                                        <Setter Property="Text" Value="No disponible"/>
                                                        <Setter Property="Foreground" Value="Red"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Grid.Column="7"
                                            Content="⋮"
                                            Click="BtnAcciones_Click"
                                            Tag="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#8B92A5"
                                            FontSize="16"
                                            HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="3" Margin="0,15,0,0">
            <Grid>
                <TextBlock Text="Showing 1 to 10 of 1,284 results" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="‹" Foreground="{StaticResource TextSecondary}" FontSize="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource AccentRed}" CornerRadius="4" Width="30" Height="30" Margin="0,0,5,0">
                        <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="2" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="›" Foreground="{StaticResource TextSecondary}" FontSize="18" Margin="15,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
