<Window x:Class="SistemaDeVenta.test"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modern POS | Login"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0f0a0b">

    <!-- ================= RESOURCES ================= -->
    <Window.Resources>

        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryRed" Color="#ec1337"/>
        <SolidColorBrush x:Key="InputBackground" Color="#1a1415"/>
        <SolidColorBrush x:Key="TextGray" Color="#94a3b8"/>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">

            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#33ffffff"/>
            <Setter Property="Padding" Value="40,12,10,12"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="TextBox">

                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">

                            <Grid>

                                <!-- Input -->
                                <ScrollViewer x:Name="PART_ContentHost"/>

                                <!-- Watermark -->
                                <TextBlock Text="{TemplateBinding Tag}"
                                           Foreground="#44ffffff"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"
                                           x:Name="Watermark"/>

                            </Grid>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark"
                                        Property="Visibility"
                                        Value="Visible"/>
                            </Trigger>

                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Watermark"
                                        Property="Visibility"
                                        Value="Collapsed"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>


        <!-- PasswordBox Style -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">

            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="BorderBrush" Value="#33ffffff"/>
            <Setter Property="Padding" Value="40,12,10,12"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="PasswordBox">

                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">

                            <ScrollViewer x:Name="PART_ContentHost"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

    </Window.Resources>

    <!-- ================= MAIN ================= -->
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="0.8*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <Grid Grid.Column="0">

            <Grid.Background>
                <RadialGradientBrush Center="0.2,0.3"
                                     RadiusX="1.2"
                                     RadiusY="1.2">

                    <GradientStop Color="#3a1218" Offset="0"/>
                    <GradientStop Color="#0f0a0b" Offset="0.8"/>

                </RadialGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center"
                        Margin="60,0">

                <TextBlock Text="Next-Gen POS Solution."
                           FontSize="60"
                           FontWeight="Black"
                           Foreground="White"
                           Margin="0,40,0,0"/>

                <TextBlock Text="Secure. Fast. Reliable business system."
                           Foreground="{StaticResource TextGray}"
                           FontSize="18"
                           Margin="0,20,0,0"
                           Width="420"
                           TextWrapping="Wrap"/>

            </StackPanel>
            <TextBlock Text="MODERN"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Black" Margin="60,51,60,596"/>
            <TextBlock Text="POS"
                           Foreground="{StaticResource PrimaryRed}"
                           FontSize="28"
                           FontWeight="Black" Margin="60,88,60,559"/>

        </Grid>

        <!-- RIGHT -->
        <Grid Grid.Column="1"
              Background="#0c0809">

            <StackPanel Width="320"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <TextBlock Text="Welcome Back"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Login to continue"
                           Foreground="{StaticResource TextGray}"
                           Margin="0,0,0,40"/>

                <!-- USER -->
                <TextBlock Text="Username"
                           Foreground="LightGray"/>

                <Grid Margin="0,5,0,20">

                    <TextBox Style="{StaticResource ModernTextBox}"
                             Tag="Enter username"
                             x:Name="txtUser"/>

                    <TextBlock Text="👤"
                               Foreground="#64748b"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>

                </Grid>

                <!-- PASSWORD -->
                <TextBlock Text="Password"
                           Foreground="LightGray"/>

                <Grid Margin="0,5,0,30">

                    <PasswordBox Style="{StaticResource ModernPasswordBox}"
                                 x:Name="txtPassword"/>

                    <TextBlock Text="🔒"
                               Foreground="#64748b"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>

                </Grid>

                <!-- BUTTON -->
                <Button Height="55"
                        Background="{StaticResource PrimaryRed}"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Foreground="White"
                        Cursor="Hand"
                        Click="BtnLogin_Click">

                    Login to Terminal

                </Button>

            </StackPanel>

        </Grid>

    </Grid>

</Window>
