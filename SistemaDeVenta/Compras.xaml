<UserControl x:Class="SistemaDeVenta.Compras"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <UserControl.Resources>
        <!-- Estilos iguales a Ventas -->
        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <TextBlock Text="Registrar Compra"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- ========== FILA 1: PRODUCTO, PROVEEDOR, PRECIO Y CANTIDAD ========== -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Botón producto -->
                    <ColumnDefinition Width="200"/>
                    <!-- TextBox producto -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Botón proveedor -->
                    <ColumnDefinition Width="200"/>
                    <!-- TextBox proveedor -->
                    <ColumnDefinition Width="120"/>
                    <!-- TextBox precio compra -->
                    <ColumnDefinition Width="80"/>
                    <!-- Cantidad -->
                    <ColumnDefinition Width="120"/>
                    <!-- Botón agregar -->
                </Grid.ColumnDefinitions>

                <!-- BOTÓN SELECCIONAR PRODUCTO -->
                <Button Grid.Column="0" Content="🔍" Width="40" Height="28" VerticalAlignment="Top" Margin="0,16,10,0" Click="Button_Click" />

                <!-- TEXBOX PRODUCTO -->
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Producto:"/>
                    <TextBox x:Name="txtProducto" Height="28" IsReadOnly="True"/>
                </StackPanel>

                <!-- BOTÓN SELECCIONAR PROVEEDOR -->
                <Button Grid.Column="2" Content="🔍" Width="40" Height="28" VerticalAlignment="Bottom" Margin="0,0,10,0" Click="Button_Click_1" />

                <!-- TEXTBOX PROVEEDOR -->
                <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Proveedor:"/>
                    <TextBox x:Name="txtRazonSocial" Height="28" IsReadOnly="True"/>
                </StackPanel>

                <!-- PRECIO COMPRA -->
                <StackPanel Grid.Column="4" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Precio Compra:"/>
                    <TextBox x:Name="txtPrecioCompra" Height="28" IsReadOnly="True"/>
                </StackPanel>

                <!-- CANTIDAD -->
                <StackPanel Grid.Column="5" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Cantidad:"/>
                    <TextBox x:Name="cbCantidad" Height="28" Text="1" HorizontalContentAlignment="Center" RenderTransformOrigin="0.493,1.22" TextAlignment="Center"/>
                </StackPanel>

                <!-- BOTÓN AGREGAR -->
                <Button Grid.Column="6"
                        Content="Agregar"
                        Background="#28A745" Foreground="White"
                        FontWeight="Bold"
                        Height="36"
                        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,0,0" Width="120" Click="Button_Click_2"
                        />
            </Grid>
        </Border>

        <!-- ========== FILA 2: TABLA + PANEL DERECHA ======== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- TABLA -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,10,0">
                <DataGrid x:Name="TablaCompras"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="200"/>
                        <DataGridTextColumn Header="Precio Compra" Binding="{Binding PrecioCompra}" Width="120"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                        <DataGridTextColumn Header="Sub Total" Binding="{Binding Subtotal}" Width="100"/>
                        <DataGridTemplateColumn Header="Eliminar" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑" Width="40" Height="28" Background="#DC3545" Foreground="White" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- PANEL DERECHA -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Total a Pagar:" FontWeight="Bold"/>
                <TextBox x:Name="txtTotal" Height="28" Margin="0,5,0,25" IsReadOnly="True"/>
                <Button Content="Registrar"
                        Background="#007BFF"
                        Foreground="White"
                        Height="45"
                        FontWeight="Bold" Click="Button_Click_3"></Button>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
