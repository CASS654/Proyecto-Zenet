<UserControl x:Class="SistemaDeVenta.Views.ProveedoresNUEVO"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#080B10"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>

        <!-- ═══════════════════════════════════════════════
             BRUSHES & COLORS
        ═══════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgMain"         Color="#080B10"/>
        <SolidColorBrush x:Key="BgPanel"        Color="#0F1520"/>
        <SolidColorBrush x:Key="BgCard"         Color="#131C2B"/>
        <SolidColorBrush x:Key="BgRow"          Color="#0D1421"/>
        <SolidColorBrush x:Key="BgRowHover"     Color="#161F30"/>
        <SolidColorBrush x:Key="BgInput"        Color="#0B1019"/>
        <SolidColorBrush x:Key="BgOverlay"      Color="#00000088"/>
        <SolidColorBrush x:Key="AccentRed"      Color="#EF1C3A"/>
        <SolidColorBrush x:Key="AccentBlue"     Color="#3B82F6"/>
        <SolidColorBrush x:Key="BorderDark"     Color="#1E2D42"/>
        <SolidColorBrush x:Key="TextWhite"      Color="#F0F4FF"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#4A5F7A"/>
        <SolidColorBrush x:Key="TextSoft"       Color="#8A9BB0"/>

        <LinearGradientBrush x:Key="AccentGrad" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#EF1C3A" Offset="0"/>
            <GradientStop Color="#C20A28" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="ShadowDeep" Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
        <DropShadowEffect x:Key="ShadowMd"   Color="#000000" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>

        <!-- ═══════════════════════════════════════════════
             ANIMATION STORYBOARDS
        ═══════════════════════════════════════════════ -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetName="SlidePanel"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="380" To="0" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SlidePanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="Overlay"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="SlideOut">
            <DoubleAnimation Storyboard.TargetName="SlidePanel"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="380" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SlidePanel"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="Overlay"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.18"/>
        </Storyboard>

        <!-- ═══════════════════════════════════════════════
             BUTTON STYLES
        ═══════════════════════════════════════════════ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AccentGrad}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Height"       Value="40"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8"
                                Effect="{StaticResource ShadowMd}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSoft}"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A2333"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentRed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E2D42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════
             INPUT STYLES
        ═══════════════════════════════════════════════ -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextWhite}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"      Value="{StaticResource AccentRed}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentRed}"/>
                                <Setter TargetName="bd" Property="Background"  Value="#0F1826"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2A3D55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input multilinea para Dirección -->
        <Style x:Key="DarkInputMulti" TargetType="TextBox" BasedOn="{StaticResource DarkInput}">
            <Setter Property="Height"       Value="80"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding"      Value="12,8"/>
        </Style>

        <!-- ═══════════════════════════════════════════════
             DATAGRID
        ═══════════════════════════════════════════════ -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="Foreground"           Value="{StaticResource TextWhite}"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="RowBackground"        Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="Transparent"/>
            <Setter Property="GridLinesVisibility"  Value="None"/>
            <Setter Property="CanUserAddRows"       Value="False"/>
            <Setter Property="HeadersVisibility"    Value="Column"/>
            <Setter Property="SelectionMode"        Value="Single"/>
            <Setter Property="SelectionUnit"        Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="12,0,12,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderDark}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="rowBd" Background="{TemplateBinding Background}"
                                Margin="0,2" CornerRadius="8">
                            <SelectiveScrollingGrid>
                                <DataGridCellsPresenter/>
                            </SelectiveScrollingGrid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rowBd" Property="Background" Value="{StaticResource BgRowHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="rowBd" Property="Background" Value="#182236"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" BorderThickness="0" Padding="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label style for form -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════
         ROOT GRID  (main content + overlay slide panel)
    ═══════════════════════════════════════════════════════════════ -->
    <Grid>

        <!-- ── MAIN CONTENT ─────────────────────────────────────── -->
        <Grid Margin="24,0,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── TABLE PANEL ── -->
            <Border Grid.Row="4" Background="#141A22"
                    CornerRadius="12" BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                    Effect="{StaticResource ShadowDeep}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Table header -->
                    <Grid Grid.Row="0" Margin="20,16,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" x:Name="TablaProveedores"
                              Margin="8,8,8,0" RowHeight="52"
                              AutoGenerateColumns="False" IsReadOnly="True">

                        <DataGrid.Columns>

                            <!-- ID -->
                            <DataGridTextColumn Header="ID" Binding="{Binding IdProveedor, StringFormat=\#PR-{0}}"
                                                Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize"   Value="12"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0,0,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- NOMBRE -->
                            <DataGridTemplateColumn Header="NOMBRE" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Nombre}"
                                                   Foreground="{StaticResource TextWhite}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- TELÉFONO -->
                            <DataGridTemplateColumn Header="TELÉFONO" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Telefono}"
                                                   Foreground="{StaticResource TextSoft}"
                                                   FontFamily="Consolas"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- DIRECCIÓN -->
                            <DataGridTemplateColumn Header="DIRECCIÓN" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Direccion}"
                                                   Foreground="{StaticResource TextSoft}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="12,0,0,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- ACTIONS -->
                            <DataGridTemplateColumn Header="ACCIONES" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Style="{StaticResource BtnIcon}" Click="ModificarProveedor_Click" Margin="2,0">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{StaticResource AccentBlue}" FontSize="14"/>
                                            </Button>
                                            <Button Style="{StaticResource BtnIcon}" Click="EliminarProveedor_Click" Margin="2,0">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{StaticResource AccentRed}" FontSize="14"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Pagination footer -->
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource BorderDark}"
                            BorderThickness="0,1,0,0"
                            Margin="20,10">
                        <Grid Margin="0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="GESTIÓN DE PROVEEDORES"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Column="1"
                                    x:Name="btnNuevoProveedor"
                                    Style="{StaticResource BtnPrimary}"
                                    Click="AbrirPanelNuevo_Click"
                                    Height="40"
                                    MinWidth="200">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="16,0">
                                    <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="ADD NEW PROVEEDOR" FontWeight="Bold"/>
                                    <Border Background="#00000033" CornerRadius="4"
                                            Margin="10,0,0,0" Padding="6,2">
                                        <TextBlock Text="F1" FontSize="11"
                                                   Foreground="#FFFFFF99" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

        </Grid>
        <!-- ── END MAIN CONTENT ── -->


        <!-- ═══════════════════════════════════════════════════════════════
             OVERLAY
        ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="Overlay"
                Background="{StaticResource BgOverlay}"
                Opacity="0"
                Visibility="Collapsed"
                MouseDown="Overlay_MouseDown"/>


        <!-- ═══════════════════════════════════════════════════════════════
             SLIDE-IN PANEL
        ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="SlidePanel"
                Width="380"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="#141A22"
                BorderBrush="{StaticResource BorderDark}"
                BorderThickness="1,0,0,0"
                Visibility="Collapsed"
                Opacity="0"
                Effect="{StaticResource ShadowDeep}">

            <Border.RenderTransform>
                <TranslateTransform X="380"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── Panel Header ── -->
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1" Padding="24,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="lblPanelTitulo" Grid.Row="0" Grid.Column="0"
                                   Text="REGISTRO DE PROVEEDOR"
                                   Foreground="{StaticResource TextWhite}"
                                   FontSize="18" FontWeight="Black"/>

                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource BtnIcon}"
                                Width="36" Height="36" Click="CerrarPanel_Click">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                       Foreground="{StaticResource TextSoft}" FontSize="14"/>
                        </Button>

                        <TextBlock x:Name="lblPanelSubtitulo" Grid.Row="1" Grid.Column="0"
                                   Text="NUEVO_PROVEEDOR : #—"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" FontFamily="Consolas" Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <!-- ── Form Fields ── -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20">

                        <TextBlock Text="Nombre Completo" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="txtNombreProveedor" Style="{StaticResource DarkInput}" Margin="0,0,0,16"/>

                        <TextBlock Text="Teléfono de Contacto" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="txtTelefonoProveedor" Style="{StaticResource DarkInput}" Margin="0,0,0,16"/>

                        <TextBlock Text="Dirección Fiscal" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="txtDireccionProveedor" Style="{StaticResource DarkInputMulti}" Margin="0,0,0,16"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── Action Buttons ── -->
                <Border Grid.Row="2" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,1,0,0" Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="btnGuardarProveedor"
                                Style="{StaticResource BtnPrimary}"
                                Click="GuardarProveedor_Click" Height="44">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="iconBoton" Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtBotonGuardar" Text="GUARDAR PROVEEDOR"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" x:Name="btnCancelar"
                                Style="{StaticResource BtnGhost}"
                                Click="CerrarPanel_Click" Height="44" MinWidth="100">
                            <TextBlock Text="CANCELAR" FontWeight="Bold" FontSize="12"/>
                        </Button>

                    </Grid>
                </Border>

            </Grid>
        </Border>
        <!-- ── END SLIDE PANEL ── -->

    </Grid>
</UserControl>
