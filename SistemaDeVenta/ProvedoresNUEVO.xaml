<UserControl x:Class="SistemaDeVenta.Views.ProveedoresNUEVO"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#0A0A0C"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

    <UserControl.Resources>
        <Color x:Key="ColorBackground">#0B0F14</Color>
        <Color x:Key="ColorPanel">#141A22</Color>
        <Color x:Key="ColorBorder">#2B3442</Color>
        <Color x:Key="ColorPrimary">#EF1C3A</Color>
        <Color x:Key="ColorTextSoft">#8A94A6</Color>

        <SolidColorBrush x:Key="BorderBrushDark" Color="{StaticResource ColorBorder}"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}"/>
        <SolidColorBrush x:Key="SoftTextBrush" Color="{StaticResource ColorTextSoft}"/>

        <LinearGradientBrush x:Key="PanelGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#141A22" Offset="0"/>
            <GradientStop Color="#1C232D" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="PanelShadow" Color="#000000" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0A0A0C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2B3442"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"/>

                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>

                            <TextBlock x:Name="Placeholder"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="#505A6B"
                                   IsHitTestVisible="False"
                                   Margin="10,0"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsKeyboardFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SoftTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0,10,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252F3D"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A222C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- FORMULARIO -->

        <Border Grid.Column="0"
                Background="{StaticResource PanelGradient}"
                CornerRadius="12"
                Padding="20"
                Effect="{StaticResource PanelShadow}">

            <StackPanel>

                <TextBlock Text="Gestión de Datos"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Nombre Completo"
                           Foreground="{StaticResource SoftTextBrush}"/>

                <TextBox x:Name="txtNombreProveedor"
                          Style="{StaticResource DarkTextBox}"
                          Tag="Ej: Insumos Globales S.A."
                          Margin="0,5,0,10"/>

                <TextBlock Text="Teléfono de Contacto"
                           Foreground="{StaticResource SoftTextBrush}"/>

                <TextBox x:Name="txtTelefonoProveedor"
                          Style="{StaticResource DarkTextBox}"
                          Tag="+1 (555) 000-0000"
                          Margin="0,5,0,10"/>

                <TextBlock Text="Dirección Fiscal"
                           Foreground="{StaticResource SoftTextBrush}"/>

                <TextBox x:Name="txtDireccionProveedor"
                          Style="{StaticResource DarkTextBox}"
                          Tag="Calle, Número, Ciudad y Estado"
                          Height="70"
                          AcceptsReturn="True"
                          TextWrapping="Wrap"
                          Margin="0,5,0,20"/>

                <Button x:Name="btnGuardarProveedor"
                        Style="{StaticResource PrimaryButton}"
                        Click="GuardarProveedor_Click">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE74E;"
                                   Margin="0,0,6,0"/>

                        <TextBlock Text="Guardar Proveedor"/>

                    </StackPanel>

                </Button>

            </StackPanel>

        </Border>

        <!-- TABLA -->

        <Border Grid.Column="2"
                Background="{StaticResource PanelGradient}"
                CornerRadius="12"
                Padding="20"
                Effect="{StaticResource PanelShadow}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Lista de Proveedores"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,20"/>

                <DataGrid Grid.Row="1"
                          x:Name="TablaProveedores"
                          RowHeight="45"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="NOMBRE"
                                            Binding="{Binding Nombre}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="TELÉFONO"
                                            Binding="{Binding Telefono}"
                                            Width="*"/>

                        <DataGridTextColumn Header="DIRECCIÓN"
                                            Binding="{Binding Direccion}"
                                            Width="2*"/>

                        <!-- BOTONES ACCIÓN -->

                        <DataGridTemplateColumn Header="ACCIONES" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">

                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Margin="0,0,8,0"
                                                Click="ModificarProveedor_Click">

                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE70F;"
                                                       Foreground="SkyBlue"
                                                       FontSize="16"/>

                                        </Button>

                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="EliminarProveedor_Click">

                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE74D;"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontSize="16"/>

                                        </Button>

                                    </StackPanel>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>

</UserControl>