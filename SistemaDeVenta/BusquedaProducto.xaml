<Window x:Class="SistemaDeVentaPrueba.BusquedaProducto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Search"
        Height="650"
        Width="1000"
        Background="#0E1A2B"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="40">

        <Border Background="#13233A"
                CornerRadius="15"
                Padding="25">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <DockPanel Grid.Row="0" Margin="0 0 0 20">
                    <TextBlock Text="Product Search"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               DockPanel.Dock="Left"/>

                    <TextBlock Text="STORE: MAIN BRANCH"
                               Foreground="#7A8CA5"
                               FontSize="12"
                               HorizontalAlignment="Right"
                               DockPanel.Dock="Right"/>
                </DockPanel>

                <!-- SEARCH BOX -->
                <Border Grid.Row="1"
                        Background="#0E1A2B"
                        BorderBrush="#FF2F45"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0 0 0 20">

                    <TextBox x:Name="txtBuscar"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             FontSize="16"
                             CaretBrush="White"/>
                </Border>

                <!-- DATA SECTION -->
                <Grid Grid.Row="2">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- FILTER BAR -->
                    <DockPanel Grid.Row="0" Margin="0 0 0 10">

                        <!-- FILTER BUTTON -->
                        <Button Background="#1F2E4A"
                                BorderBrush="#FF2F45"
                                BorderThickness="1"
                                Padding="12,6"
                                Margin="0 0 15 0"
                                Cursor="Hand">

                            <StackPanel Orientation="Horizontal">

                                <!-- FILTER ICON -->
                                <Path Data="M3,4 L21,4 L14,12 L14,20 L10,18 L10,12 Z"
                                      Fill="#FF2F45"
                                      Width="14"
                                      Height="14"
                                      Stretch="Uniform"
                                      Margin="0,0,8,0"/>

                                <TextBlock Text="Filters (F3)"
                                           Foreground="#FF2F45"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="0 results found"
                                   Foreground="#7A8CA5"
                                   VerticalAlignment="Center"/>

                        <!-- SORT SECTION -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Right">

                            <!-- SORT ICON -->
                            <Path Data="M7,3 L11,7 L3,7 Z M3,17 L11,17 L7,21 Z"
                                  Fill="#7A8CA5"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center"/>

                            <TextBlock Text="SORTED BY: RELEVANCE"
                                       Foreground="#7A8CA5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                    </DockPanel>

                    <!-- DATAGRID -->
                    <DataGrid x:Name="dgProductos"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              Background="#13233A"
                              BorderBrush="#2C3E5A"
                              BorderThickness="0"
                              Foreground="White"
                              RowBackground="#13233A"
                              AlternatingRowBackground="#1A2B45"
                              GridLinesVisibility="None"
                              SelectionMode="Single"
                              RowHeight="45">

                        <!-- HEADER STYLE -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1F2E4A"/>
                                <Setter Property="Foreground" Value="#A8B3C7"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="BorderBrush" Value="#2C3E5A"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <!-- ROW STYLE -->
                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#13233A"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#243B5E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="#"
                                                Binding="{Binding Id}"
                                                Width="60"/>

                            <DataGridTextColumn Header="PRODUCT NAME"
                                                Binding="{Binding Nombre}"
                                                Width="*"/>

                            <DataGridTextColumn Header="PRICE"
                                                Binding="{Binding Precio}"
                                                Width="120"/>

                            <DataGridTextColumn Header="STOCK"
                                                Binding="{Binding Stock}"
                                                Width="120"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

                <!-- FOOTER -->
                <DockPanel Grid.Row="3" Margin="0 20 0 0">

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Enter  Select Product   ↑↓ Navigate   Esc Close"
                                   Foreground="#7A8CA5"/>
                    </StackPanel>

                    <Button Content="ADD SELECTED"
                            DockPanel.Dock="Right"
                            Background="#FF2F45"
                            Foreground="White"
                            Padding="20,10"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Right"/>
                </DockPanel>

            </Grid>
        </Border>

    </Grid>
</Window>
