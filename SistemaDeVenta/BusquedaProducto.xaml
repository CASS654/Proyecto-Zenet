<Window x:Class="SistemaDeVentaPrueba.BusquedaProducto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Search"
        Height="700" Width="1050"
        Background="#070B14" 
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF2D46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#FF2D46"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8,0,0,8" Padding="15,8">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KbdBadge" TargetType="Border">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,10,10,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="#0F172A" CornerRadius="12" BorderBrush="#1E293B" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="25,20">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M15.5,14h-.79l-.28-.27C15.41,12.59,16,11.11,16,9.5,16,5.91,13.09,3,9.5,3S3,5.91,3,9.5,5.91,16,9.5,16c1.61,0,3.09-.59,4.23-1.57l.27.28v.79l5,4.99L20.49,19l-4.99-5zm-6,0C7.01,14,5,11.99,5,9.5S7.01,5,9.5,5,14,7.01,14,9.5,11.99,14,9.5,14z" 
                                  Fill="#FF2D46" Width="20" Height="20" Stretch="Uniform"/>
                            <TextBlock Text="Product Search" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="STORE: MAIN BRANCH" Foreground="#475569" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Background="#131C2E" BorderBrush="#1E293B" BorderThickness="0,1" Padding="25,15">
                    <StackPanel Orientation="Horizontal">

                        <Button Style="{StaticResource FilterButtonStyle}" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Filters" Foreground="#FF2D46" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border Background="#FF2D46" CornerRadius="3" Padding="4,1">
                                    <TextBlock Text="F3" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <Border Background="#070B14" BorderBrush="#334155" BorderThickness="0,1,1,1" CornerRadius="0,8,8,0" Width="849" Padding="12,6" Height="34" KeyDown="Border_KeyDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="M15.5,14h-.79l-.28-.27C15.41,12.59,16,11.11,16,9.5,16,5.91,13.09,3,9.5,3S3,5.91,3,9.5,5.91,16,9.5,16c1.61,0,3.09-.59,4.23-1.57l.27.28v.79l5,4.99L20.49,19l-4.99-5zm-6,0C7.01,14,5,11.99,5,9.5S7.01,5,9.5,5,14,7.01,14,9.5,11.99,14,9.5,14z" 
                                      Fill="#334155" Height="19" VerticalAlignment="Center" Margin="0,0,6,0" Stretch="Fill"/>
                                <TextBox x:Name="txtBuscar" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" CaretBrush="#FF2D46" Grid.ColumnSpan="2" Margin="23,0,0,0" TextChanged="txtBuscar_TextChanged"/>
                                <TextBlock Grid.Column="2" Text="F3 to filter" Foreground="#334155" FontStyle="Italic" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <DataGrid x:Name="dgProductos" 
          Grid.Row="2" 
          AutoGenerateColumns="False" 
          CanUserAddRows="False" 
          IsReadOnly="True"
          Background="Transparent" 
          BorderThickness="0" 
          HeadersVisibility="Column" 
          GridLinesVisibility="None" 
          RowHeight="70"
          SelectionMode="Single"
          SelectionUnit="FullRow"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden">

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#FF2D46"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#1E293B"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="#" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Id}" Foreground="#FF2D46" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="PRODUCT NAME" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock Text="{Binding Nombre}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="SKU: WIN-0045-RE" Foreground="#64748B" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="PRICE" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Precio, StringFormat={}{0:C}}" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="STOCK" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#1A2E26" CornerRadius="12" Padding="12,5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Stock, StringFormat={}{0} In Stock}" Foreground="#4ADE80" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="3" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="0,1,0,0" Padding="25">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource KbdBadge}">
                                <TextBlock Text="Enter" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Select Product" Foreground="#64748B" FontSize="12" Margin="0,0,25,0"/>
                            <Border Style="{StaticResource KbdBadge}">
                                <TextBlock Text="Esc" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Close" Foreground="#64748B" FontSize="12"/>
                        </StackPanel>
                        <Button Style="{StaticResource ModernButtonStyle}" Content="ADD SELECTED" DockPanel.Dock="Right" HorizontalAlignment="Right" FontWeight="Bold"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>