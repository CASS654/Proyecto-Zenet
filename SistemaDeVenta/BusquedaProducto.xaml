<Window x:Class="SistemaDeVenta.BusquedaProducto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
        Title="Product Search"
        Height="700" Width="1050"

        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"

        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF2D46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">

                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#FF2D46"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8,0,0,8" Padding="15,8">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KbdBadge" TargetType="Border">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
    </Window.Resources>

    <Grid>
        <Border Background="#0F172A"
            CornerRadius="12"
            BorderBrush="#1E293B"
            BorderThickness="1"
            Margin="20"
            ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0 + ROW 1 unificados -->
                <Border Grid.Row="0" Grid.RowSpan="2"
        Background="#141A22"
        BorderBrush="#141A22"
        BorderThickness="0,0,0,1"
        Padding="25,20">
                    <StackPanel>

                        <!-- Header -->
                        <DockPanel Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M15.5,14h-.79l-.28-.27C15.41,12.59,16,11.11,16,9.5,16,5.91,13.09,3,9.5,3S3,5.91,3,9.5,5.91,16,9.5,16c1.61,0,3.09-.59,4.23-1.57l.27.28v.79l5,4.99L20.49,19l-4.99-5zm-6,0C7.01,14,5,11.99,5,9.5S7.01,5,9.5,5,14,7.01,14,9.5,11.99,14,9.5,14z"
                      Fill="#EF1C3A" Width="20" Height="20" Stretch="Uniform"/>
                                <TextBlock Text="Product Search" Foreground="White" FontSize="18"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                         </DockPanel>

                        <!-- Search Bar con borde rojo -->
                        <Border Background="#0B0F14"
                BorderBrush="#EF1C3A"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Path Grid.Column="0"
                      Data="M15.5,14h-.79l-.28-.27C15.41,12.59,16,11.11,16,9.5,16,5.91,13.09,3,9.5,3S3,5.91,3,9.5,5.91,16,9.5,16c1.61,0,3.09-.59,4.23-1.57l.27.28v.79l5,4.99L20.49,19l-4.99-5zm-6,0C7.01,14,5,11.99,5,9.5S7.01,5,9.5,5,14,7.01,14,9.5,11.99,14,9.5,14z"
                      Fill="#2B3442" Width="18" Height="18"
                      Stretch="Uniform" VerticalAlignment="Center" Margin="4,0,10,0"/>

                                <TextBox x:Name="txtBuscar"
                         Grid.Column="1"
                         Background="Transparent"
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="14"
                         Height="30"
                         VerticalContentAlignment="Center"
                         CaretBrush="#EF1C3A"
                         TextChanged="txtBuscar_TextChanged"/>

                                <!-- Placeholder -->
                                <TextBlock Grid.Column="1"
                           IsHitTestVisible="False"
                           Text="Buscar producto o escanear código..."
                           VerticalAlignment="Center"
                           Foreground="#3A424F"
                           FontSize="14"
                           FontStyle="Italic">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBuscar}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="2"
                           Text="F3 to filter"
                           Foreground="#2B3442"
                           FontStyle="Italic"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Margin="10,0,4,0"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>


                <DataGrid x:Name="dgProductos" 
          Grid.Row="2" 
          AutoGenerateColumns="False" 
          CanUserAddRows="False" 
          IsReadOnly="True"
          Background="#1a1b24" 
          BorderThickness="0" 
          HeadersVisibility="Column" 
          GridLinesVisibility="None" 
          RowHeight="70"
          SelectionMode="Single"
          SelectionUnit="FullRow"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden" SelectionChanged="dgProductos_SelectionChanged">

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#FF2D46"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#1a1b24" />
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#1a1b24"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground"                 Value="#8A94A6"/>
                            <Setter Property="FontSize"                   Value="11"/>
                            <Setter Property="FontWeight"                 Value="Bold"/>
                            <Setter Property="Padding"                    Value="15,10,10,10"/>
                            <Setter Property="BorderThickness"            Value="0,0,0,1"/>
                            <Setter Property="BorderBrush"                Value="#141A22"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Border Background="#141A22"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="#" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Id}" Foreground="#FF2D46" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="PRODUCT NAME" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock Text="{Binding Nombre}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="SKU: WIN-0045-RE" Foreground="#64748B" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="PRICE" Width="130">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground"      Value="#8A94A6"/>
                                    <Setter Property="FontSize"        Value="11"/>
                                    <Setter Property="FontWeight"      Value="Bold"/>
                                    <Setter Property="Padding"         Value="0,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush"     Value="#141A22"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border Background="#141A22"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Precio, StringFormat={}{0:C}}"
                       Foreground="White" FontWeight="Bold" FontSize="16"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="STOCK" Width="150">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground"      Value="#8A94A6"/>
                                    <Setter Property="FontSize"        Value="11"/>
                                    <Setter Property="FontWeight"      Value="Bold"/>
                                    <Setter Property="Padding"         Value="0,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush"     Value="#141A22"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border Background="#141A22"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="12,5"
                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <!-- Verde: stock normal (>10) -->
                                                <Setter Property="Background" Value="#1A2E26"/>
                                                <Style.Triggers>
                                                    <!-- Amarillo: pocos (entre 4 y 10) -->
                                                    <DataTrigger Binding="{Binding StockNivel}" Value="Bajo">
                                                        <Setter Property="Background" Value="#2E2A10"/>
                                                    </DataTrigger>
                                                    <!-- Rojo: casi nada (entre 1 y 3) -->
                                                    <DataTrigger Binding="{Binding StockNivel}" Value="Critico">
                                                        <Setter Property="Background" Value="#2E1010"/>
                                                    </DataTrigger>
                                                    <!-- Gris: sin stock (0) -->
                                                    <DataTrigger Binding="{Binding StockNivel}" Value="Agotado">
                                                        <Setter Property="Background" Value="#1E1E1E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Stock, StringFormat={}{0} In Stock}"
                       FontSize="11" FontWeight="Bold" TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <!-- Verde por defecto -->
                                                    <Setter Property="Foreground" Value="#4ADE80"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StockNivel}" Value="Bajo">
                                                            <Setter Property="Foreground" Value="#FACC15"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StockNivel}" Value="Critico">
                                                            <Setter Property="Foreground" Value="#F87171"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StockNivel}" Value="Agotado">
                                                            <Setter Property="Foreground" Value="#6B7280"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2"
        Background="#141A22"
        BorderBrush="#1E293B"
        BorderThickness="0,1,0,0"
        Padding="25"
        CornerRadius="0,0,12,12" HorizontalAlignment="Left" Margin="0,441,0,0" Grid.RowSpan="2" Width="1008">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource KbdBadge}">
                                <TextBlock Text="Enter" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Select Product" Foreground="#64748B" FontSize="12" Margin="0,0,25,0"/>
                            <Border Style="{StaticResource KbdBadge}">
                                <TextBlock Text="Esc" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Close" Foreground="#64748B" FontSize="12"/>
                        </StackPanel>
                        <Button Style="{StaticResource ModernButtonStyle}" Content="ADD SELECTED" DockPanel.Dock="Right" HorizontalAlignment="Right" FontWeight="Bold" Click="Button_Click"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>