<UserControl x:Class="SistemaDeVenta.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SistemaDeVenta"
             mc:Ignorable="d" 
             Background="#0B0F14"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <SolidColorBrush x:Key="ColorBackground" Color="#0B0F14"/>
        <SolidColorBrush x:Key="ColorPanel" Color="#141A22"/>
        <SolidColorBrush x:Key="ColorBorder" Color="#2B3442"/>
        <SolidColorBrush x:Key="ColorPrimary" Color="#4A90E2"/>
        <SolidColorBrush x:Key="ColorTextSoft" Color="#8A94A6"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>

        <Style x:Key="CustomDataGridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="0,12">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,1,0,1"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0AFFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#204A90E2"/>
                    <Setter Property="BorderBrush" Value="{StaticResource ColorPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTextSoft}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,0,10,15"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ColorBackground}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="BIENVENIDO AL SISTEMA DE VENTAS" 
                       Foreground="White" 
                       FontSize="28" 
                       FontWeight="ExtraBold" 
                       Margin="10,0,0,25" 
                       HorizontalAlignment="Left"/>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,10">
                <Border Background="{StaticResource ColorPanel}" CornerRadius="12" Margin="8" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource ColorPrimary}" CornerRadius="10" Width="45" Height="45" VerticalAlignment="Center">
                            <TextBlock Text="💰" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Ventas Hoy" Foreground="{StaticResource ColorTextSoft}" FontSize="12"/>
                            <TextBlock x:Name="TxtVentasHoy" Text="$0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{StaticResource ColorPanel}" CornerRadius="12" Margin="8" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource ColorPrimary}" CornerRadius="10" Width="45" Height="45" VerticalAlignment="Center">
                            <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Productos Vendidos" Foreground="{StaticResource ColorTextSoft}" FontSize="12"/>
                            <TextBlock x:Name="TxtProductosVendidos" Text="0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{StaticResource ColorPanel}" CornerRadius="12" Margin="8" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource ColorPrimary}" CornerRadius="10" Width="45" Height="45" VerticalAlignment="Center">
                            <TextBlock Text="👥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Clientes" Foreground="{StaticResource ColorTextSoft}" FontSize="12"/>
                            <TextBlock x:Name="TxtClientes" Text="0" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{StaticResource ColorPanel}" CornerRadius="12" Margin="8" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#EF1C3A" CornerRadius="10" Width="45" Height="45" VerticalAlignment="Center">
                            <TextBlock Text="⚠" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Productos Bajos" Foreground="{StaticResource ColorTextSoft}" FontSize="12"/>
                            <TextBlock x:Name="TxtBajoStock" Text="0" Foreground="#EF1C3A" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource ColorPanel}" CornerRadius="14" BorderBrush="{StaticResource ColorBorder}" BorderThickness="1" Padding="15" Margin="8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Productos más vendidos" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <DataGrid x:Name="TopProductsGrid" AutoGenerateColumns="False" Background="Transparent" BorderThickness="0" 
                                  GridLinesVisibility="None" HeadersVisibility="Column" RowBackground="Transparent" 
                                  AlternatingRowBackground="Transparent" Foreground="White" FontWeight="Bold" 
                                  CanUserAddRows="False" CanUserResizeRows="False" CanUserResizeColumns="False"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  CellStyle="{StaticResource CustomDataGridCell}" RowStyle="{StaticResource CustomDataGridRow}" 
                                  ColumnHeaderStyle="{StaticResource CustomDataGridColumnHeader}">
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*"/>
                                <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="*"/>
                                <DataGridTextColumn Header="Precio" Binding="{Binding Precio}" Width="*"/>
                                <DataGridTextColumn Header="Vendidos" Binding="{Binding Vendidos}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource ColorPanel}" CornerRadius="14" BorderBrush="{StaticResource ColorBorder}" BorderThickness="1" Padding="15" Margin="8">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#F59E0B" Width="30" Height="30" CornerRadius="8" VerticalAlignment="Center">
                                <TextBlock Text="⚠" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Stock Crítico" Foreground="White" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <ListBox x:Name="LowStockList" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Nombre}" Foreground="White" FontSize="13"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Stock}" FontWeight="Bold" Margin="10,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Stock}" Value="0">
                                                                <Setter Property="Foreground" Value="#EF1C3A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Stock}" Value="10">
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <Border Height="1" Background="{StaticResource ColorBorder}" Opacity="0.6"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>