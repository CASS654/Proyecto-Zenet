<UserControl x:Class="SistemaDeVenta.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SistemaDeVenta"
             mc:Ignorable="d" 
             Background="#0A0A0C"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#141A22" Margin="20">

        <!-- Estructura principal -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Título -->
            <RowDefinition Height="Auto"/>
            <!-- KPIs -->
            <RowDefinition Height="*"/>
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- ===================== -->
        <!-- TÍTULO -->
        <!-- ===================== -->
        <TextBlock Text="Dashboard"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="10,0,0,20"/>

        <!-- ===================== -->
        <!-- KPIs -->
        <!-- ===================== -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">

            <!-- ===================== -->
            <!-- VENTAS -->
            <!-- ===================== -->
            <Border Background="#0B0F14" CornerRadius="12" Margin="8" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="Red"
                    CornerRadius="10"
                    Width="45"
                    Height="45"
                    VerticalAlignment="Center">
                        <TextBlock Text="💰"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Ventas Hoy"
                           Foreground="#8A94A6"
                           FontSize="12"/>
                        <TextBlock x:Name="TxtVentasHoy"
                           Text="$0"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===================== -->
            <!-- PRODUCTOS -->
            <!-- ===================== -->
            <Border Background="#0B0F14" CornerRadius="12" Margin="8" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="Red"
                    CornerRadius="10"
                    Width="45"
                    Height="45"
                    VerticalAlignment="Center" Margin="-10,0,10,0">
                        <TextBlock Text="📦"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel HorizontalAlignment="Right" Width="109" Grid.ColumnSpan="2" Margin="0,0,0,3">
                        <TextBlock Text="Productos Vendidos"
                           Foreground="#8A94A6"
                           FontSize="12" Width="107"/>
                        <TextBlock x:Name="TxtProductosVendidos"
                           Text="0"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold" Width="94" Height="27"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===================== -->
            <!-- CLIENTES -->
            <!-- ===================== -->
            <Border Background="#0B0F14" CornerRadius="12" Margin="8" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="Red"
                    CornerRadius="10"
                    Width="45"
                    Height="45"
                    VerticalAlignment="Center">
                        <TextBlock Text="👥"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Clientes"
                           Foreground="#8A94A6"
                           FontSize="12"/>
                        <TextBlock x:Name="TxtClientes"
                           Text="0"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===================== -->
            <!-- BAJO STOCK -->
            <!-- ===================== -->
            <Border Background="#0B0F14" CornerRadius="12" Margin="8" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="Red"
                    CornerRadius="10"
                    Width="45"
                    Height="45"
                    VerticalAlignment="Center">
                        <TextBlock Text="⚠"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Productos Bajos"
                           Foreground="#8A94A6"
                           FontSize="12"/>
                        <TextBlock x:Name="TxtBajoStock"
                           Text="0"
                           Foreground="#EF1C3A"
                           FontSize="22"
                           FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

        </UniformGrid>

        <!-- ===================== -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ===================== -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22*"/>
                <ColumnDefinition Width="485*"/>
                <ColumnDefinition Width="253*"/>
            </Grid.ColumnDefinitions>

            <!-- PRODUCTOS MÁS VENDIDOS -->
            <Border Background="#0B0F14"
                    CornerRadius="14"
                    BorderBrush="#2B3442"
                    BorderThickness="1"
                    Padding="15"
                    Margin="0,0,10,0" Grid.ColumnSpan="2">

                <StackPanel>

                    <TextBlock Text="Productos más vendidos"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <DataGrid x:Name="TopProductsGrid"
                              AutoGenerateColumns="False"
                              Background="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              RowBackground="#141A22"
                              AlternatingRowBackground="#1C232D"
                              Foreground="White"
                              FontWeight="Bold">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*"/>
                            <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="*"/>
                            <DataGridTextColumn Header="Precio" Binding="{Binding Precio}" Width="*"/>
                            <DataGridTextColumn Header="Vendidos" Binding="{Binding Vendidos}" Width="*"/>
                        </DataGrid.Columns>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Foreground" Value="#EF1C3A"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Background" Value="#0F172A"/>
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2B3442"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>

                </StackPanel>
            </Border>

            <Border Grid.Column="2"
        Background="#0B0F14"
        CornerRadius="14"
        BorderBrush="#2B3442"
        BorderThickness="1"
        Padding="15">

                <StackPanel>

                    <!-- HEADER -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">

                        <Border Background="Yellow"
                    Width="30"
                    Height="30"
                    CornerRadius="8"
                    VerticalAlignment="Center">

                            <TextBlock Text="⚠"
                           Foreground="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top" Height="16" Width="16" Margin="0,4,0,0"/>
                        </Border>

                        <TextBlock Text="Productos bajos"
                       Foreground="White"
                       FontSize="15"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- LISTA -->
                    <ListBox x:Name="LowStockList"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <StackPanel>

                                    <!-- ITEM -->
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Nombre -->
                                        <TextBlock Text="{Binding Nombre}"
                                       Foreground="White"
                                       FontSize="13"/>

                                        <!-- Stock con color dinámico -->
                                        <TextBlock Grid.Column="1"
                                       Text="{Binding Stock}"
                                       FontWeight="Bold"
                                       Margin="10,0,0,0">

                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                    <!-- verde -->

                                                    <Style.Triggers>
                                                        <!-- Crítico -->
                                                        <DataTrigger Binding="{Binding Stock}" Value="0">
                                                            <Setter Property="Foreground" Value="#EF1C3A"/>
                                                        </DataTrigger>

                                                        <!-- Bajo -->
                                                        <DataTrigger Binding="{Binding Stock}" Value="10">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>

                                        </TextBlock>
                                    </Grid>

                                    <!-- SEPARADOR -->
                                    <Border Height="1"
                                Background="#2B3442"
                                Opacity="0.6"/>
                                </StackPanel>

                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</UserControl>
