<Window x:Class="SistemaDeVenta.VentanaMerma"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Merma" Height="400" Width="400"
        WindowStartupLocation="CenterScreen" Background="#121624" 
        AllowsTransparency="True" WindowStyle="None" ResizeMode="NoResize">

    <Border BorderBrush="#FF334D" BorderThickness="1" CornerRadius="15" Background="#1C2132" Margin="10">
        <StackPanel Margin="25">
            <TextBlock Text="REGISTRAR MERMA" Foreground="#FF334D" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock x:Name="lblProducto" Text="Producto: [Nombre]" Foreground="White" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock x:Name="lblStockActual" Text="Stock actual: [0]" Foreground="#8B92A5" FontSize="12" Margin="0,0,0,20"/>

            <TextBlock Text="Cantidad a retirar:" Foreground="#8B92A5" Margin="0,0,0,5"/>
            <TextBox x:Name="txtCantidad" Padding="10" Background="#0D1117" Foreground="White" BorderBrush="#2D3348" Margin="0,0,0,15"/>

            <TextBlock Text="Razón de la merma:" Foreground="#8B92A5" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbRazon" Padding="8" Margin="0,0,0,25" Background="#0D1117" Foreground="Black">
                <ComboBoxItem Content="Producto Dañado" IsSelected="True"/>
                <ComboBoxItem Content="Fecha de Vencimiento"/>
                <ComboBoxItem Content="Error de Inventario"/>
                <ComboBoxItem Content="Robo / Extravío"/>
            </ComboBox>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Cancelar" Grid.Column="0" Margin="0,0,10,0" Background="Transparent" Foreground="#8B92A5" Click="BtnCancelar_Click" Cursor="Hand"/>
                <Button Content="Confirmar" Grid.Column="1" Background="#FF334D" Foreground="White" FontWeight="Bold" Padding="10" Click="BtnGuardar_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>