<UserControl x:Class="SistemaDeVenta.Proveedores"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F2F2F2">

    <!-- ========================
         RECURSOS — ESTILOS
         (Mismos del UserControl Usuarios)
    ========================== -->
    <UserControl.Resources>

        <!-- ===== DATAGRID ===== -->
        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- SOMBRA -->
        <DropShadowEffect x:Key="DropShadow"
                          BlurRadius="12"
                          ShadowDepth="2"
                          Opacity="0.25"/>

        <!-- CONTEXT MENU (OPCIONES DE FILTRO) -->
        <Style TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="White"
                        CornerRadius="8"
                        Padding="5"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        SnapsToDevicePixels="True"
                        MinWidth="150"
                        Effect="{DynamicResource DropShadow}">
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======== MENUITEM MODERNO ======== -->
        <Style TargetType="MenuItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="5">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F2F2F2"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D0E8FF"/>
                                <Setter Property="Foreground" Value="#0066CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="MenuFiltroTemplate">
            <MenuItem Header="Nombre" Click="FiltroMenu_Click"/>
            <MenuItem Header="Teléfono" Click="FiltroMenu_Click"/>
            <MenuItem Header="Dirección" Click="FiltroMenu_Click"/>
        </ContextMenu>


    </UserControl.Resources>


    <!-- =========================
         INTERFAZ  
    ========================== -->
    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==========================================================
                         PANEL IZQUIERDO — FORMULARIO
        ========================================================== -->
        <Border Background="White" Margin="0,0,10,0" Padding="15">
            <StackPanel>

                <TextBlock Text="Detalle Proveedor"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <!-- Nombre -->
                <TextBlock Text="Nombre:"/>
                <TextBox x:Name="txtNombre"
                         Height="28"
                         Margin="0,5,0,15"/>

                <!-- Teléfono -->
                <TextBlock Text="Teléfono:"/>
                <TextBox x:Name="txtTelefono"
                         Height="28"
                         Margin="0,5,0,15"/>

                <!-- Dirección -->
                <TextBlock Text="Dirección:"/>
                <TextBox x:Name="txtDireccion"
                         Height="28"
                         Margin="0,5,0,25"/>

                <!-- BOTONES -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Guardar" Height="30" Width="80" Margin="5"
                            Background="#28A745" Foreground="White" Click="Button_Click_1"/>
                    <Button Content="Modificar" Height="30" Width="80" Margin="5"
                            Background="#007BFF" Foreground="White" Click="Button_Click_2"/>
                    <Button Content="Eliminar" Height="30" Width="80" Margin="5"
                            Background="#DC3545" Foreground="White" Click="Button_Click_3"/>
                </StackPanel>

            </StackPanel>
        </Border>


        <!-- ==========================================================
                    PANEL DERECHO — BUSCADOR Y TABLA
        ========================================================== -->
        <Border Grid.Column="1" Background="White" Padding="15">
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- BUSQUEDA (MISMO DISEÑO QUE USUARIOS) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBox x:Name="txtBuscar"
                             Width="491"
                             Height="28"
                             Margin="0,0,10,0" KeyDown="txtBuscar_KeyDown"/>

                    <Button Width="40" Height="28"
                            Background="#007BFF" Foreground="White"
                            Content="🔍" Click="Button_Click"/>

                    <!-- BOTÓN FILTRO IGUAL AL USERCONTROL USUARIOS -->
                    <Button x:Name="btnFiltro"
                            Width="35" Height="35"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ContextMenu="{StaticResource MenuFiltroTemplate}" Click="btnFiltro_Click_1">
                        <Image Source="/Iconos/filter_icon_155401.png"
                               Width="22"
                               Height="22"/>
                    </Button>

                </StackPanel>


                <!-- TABLA -->
                <DataGrid x:Name="TablaProveedores"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Margin="0,10,0,0" SelectionChanged="TablaProveedores_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding IdProveedor}"
                                            Width="60"/>

                        <DataGridTextColumn Header="Nombre"
                                            Binding="{Binding Nombre}"
                                            Width="200"/>

                        <DataGridTextColumn Header="Teléfono"
                                            Binding="{Binding Telefono}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Dirección"
                                            Binding="{Binding Direccion}"
                                            Width="250"/>

                    </DataGrid.Columns>
w
                </DataGrid>

            </Grid>
        </Border>

    </Grid>

</UserControl>
