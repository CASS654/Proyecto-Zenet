<UserControl x:Class="SistemaDeVenta.HistorialVenta"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F2F2F2">

    <!-- ========================
         RECURSOS
    ========================== -->
    <UserControl.Resources>

        <!-- ========================
             ESTILO DEL DATAGRID
        ========================== -->
        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ENCABEZADO AZUL -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="White"
                        CornerRadius="8"
                        Padding="5"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        SnapsToDevicePixels="True"
                        MinWidth="150"
                        Effect="{DynamicResource DropShadow}">
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SOMBRA GENERAL -->
        <DropShadowEffect x:Key="DropShadow"
                  BlurRadius="12"
                  ShadowDepth="2"
                  Opacity="0.25"/>

        <!-- ======== MENUITEM MODERNO ======== -->
        <Style TargetType="MenuItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="5">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F2F2F2"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D0E8FF"/>
                                <Setter Property="Foreground" Value="#0066CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="MenuFiltroTemplate">
            <MenuItem Header="ID Detalle" Click="FiltroMenu_Click"/>
            <MenuItem Header="ID Venta" Click="FiltroMenu_Click"/>
            <MenuItem Header="ID Producto" Click="FiltroMenu_Click"/>
            <MenuItem Header="Producto" Click="FiltroMenu_Click"/>
            <MenuItem Header="Cantidad" Click="FiltroMenu_Click"/>
        </ContextMenu>

    </UserControl.Resources>


    <!-- =========================
         INTERFAZ GENERAL
    ========================== -->
    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- TÍTULO -->
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">

            <TextBlock Text="Reporte Ventas"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,40,0"/>
        </StackPanel>


        <!-- CONTENIDO -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="5"
                Padding="15">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <!-- ============================
                     BUSCADOR + FILTRO BONITO
                ============================ -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <TextBox x:Name="txtBuscar"
                             Width="500"
                             Height="32"
                             Margin="0,0,10,0" KeyDown="txtBuscar_KeyDown"/>

                    <Button Width="40" Height="32"
                            Background="#007BFF"
                            Foreground="White"
                            Content="🔍"
                            Click="Buscar_Click"/>

                    <Button x:Name="btnFiltro"
                            Width="35" Height="35"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="btnFiltro_Click"
                            ContextMenu="{StaticResource MenuFiltroTemplate}">
                        <Image Source="/Iconos/filter_icon_155401.png"
                               Width="22" Height="22"/>
                    </Button>

                </StackPanel>


                <!-- ============================
                     TABLA MODERNA
                ============================ -->
                <DataGrid x:Name="TablaReporte"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Margin="0,10,0,0">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID Detalle" Binding="{Binding IdDetalle}" Width="80"/>
                        <DataGridTextColumn Header="ID Venta" Binding="{Binding IdVenta}" Width="80"/>
                        <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="150"/>
                        <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="120"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                        <DataGridTextColumn Header="Precio Unitario" Binding="{Binding PrecioUnitario}" Width="120"/>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal}" Width="120"/>
                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>

</UserControl>
