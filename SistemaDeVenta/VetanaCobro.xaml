<Window x:Class="SistemaDeVentaPrueba.VetanaCobro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ModernPOS v2.4" Height="900" Width="1300"
        Background="#121624" FontFamily="Segoe UI" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#121624"/>
        <SolidColorBrush x:Key="PanelDark" Color="#1C2132"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2D3348"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FF334D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B92A5"/>

        <Style x:Key="KeycapStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D3348"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border Background="{StaticResource AccentRed}" Width="30" Height="20" CornerRadius="4" Margin="0,0,10,0">
                    <TextBlock Text="▶" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                </Border>
                <TextBlock Text="ModernPOS" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text=" v2.4" Foreground="{StaticResource TextSecondary}" FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="ALEX RODRIGUEZ" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                    <TextBlock Text="Terminal #04 • Cashier" Foreground="{StaticResource AccentRed}" FontSize="12" HorizontalAlignment="Right"/>
                </StackPanel>
                <Ellipse Width="40" Height="40" Fill="#D1D5DB" Margin="0,0,20,0"/>

                <Border BorderBrush="{StaticResource AccentRed}" BorderThickness="1" Background="#20FF334D" CornerRadius="8" Padding="15,8">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource AccentRed}" CornerRadius="4" Padding="4,1" Margin="0,0,8,0">
                            <TextBlock Text="ESC" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="LOGOUT ➔" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <Border BorderBrush="{StaticResource AccentRed}" BorderThickness="1" CornerRadius="10" Background="{StaticResource PanelDark}" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="|||" Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontSize="20" Margin="0,0,15,0" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="90"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="QTY:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <Border Background="#33FF334D" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="1" Foreground="{StaticResource AccentRed}" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" 
                             FontSize="20" Margin="20,0,0,0" VerticalAlignment="Center" 
                             Text="4* [Product Name/Barcode] or [F2] to search..."/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="SEARCHING... " Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Border Background="{StaticResource AccentRed}" CornerRadius="8" Padding="20,10">
                            <TextBlock Text="+ ADD ITEM" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            <TextBlock Text="ⓘ QUICK TIP: USE [QTY]* PREFIX FOR BULK ENTRY (E.G., 4*77402)" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="5,10,0,0" FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="10" Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20" Background="{StaticResource PanelDark}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ID" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="DESCRIPTION [arrow keys to select]" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="UNIT PRICE" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="QTY [F6]" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="UNIT" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="TOTAL" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="{StaticResource BorderDark}" Margin="0"/>

                    <StackPanel Grid.Row="1">
                        <Grid Margin="20,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="#77402" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="HyperX Alloy Origins 60" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15"/>
                                <TextBlock Text="Mechanical Gaming Keyboard (Red Switch)" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="$99.99" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{StaticResource BorderDark}" CornerRadius="4" Width="24" Height="24">
                                    <TextBlock Text="-" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="1" Foreground="White" FontWeight="Bold" Margin="15,0" VerticalAlignment="Center"/>
                                <Border Background="{StaticResource BorderDark}" CornerRadius="4" Width="24" Height="24">
                                    <TextBlock Text="+" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <Border Grid.Column="4" Background="{StaticResource BorderDark}" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="PCS" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            </Border>
                            <TextBlock Grid.Column="5" Text="$99.99" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Background="#20FF334D" BorderBrush="{StaticResource AccentRed}" BorderThickness="0,1,0,1" Padding="20,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#44109" Foreground="{StaticResource AccentRed}" FontWeight="Bold" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Logitech G Pro X Superlight" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15"/>
                                    <TextBlock Text="Wireless Gaming Mouse - White" Foreground="{StaticResource AccentRed}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="$149.00" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#40FF334D" CornerRadius="4" Width="24" Height="24">
                                        <TextBlock Text="-" Foreground="{StaticResource AccentRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Background="#121624" CornerRadius="4" Margin="10,0" Padding="10,2">
                                        <TextBlock Text="2" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Background="#40FF334D" CornerRadius="4" Width="24" Height="24">
                                        <TextBlock Text="+" Foreground="{StaticResource AccentRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <Border Grid.Column="4" Background="{StaticResource AccentRed}" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="PCS" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Grid.Column="5" Text="$298.00" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Grid Margin="20,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="#99201" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="SteelSeries QcK Edge - XL" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15"/>
                                <TextBlock Text="Stitched Edge Cloth Gaming Mouse Pad" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="$24.99" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{StaticResource BorderDark}" CornerRadius="4" Width="24" Height="24">
                                    <TextBlock Text="-" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="1" Foreground="White" FontWeight="Bold" Margin="15,0" VerticalAlignment="Center"/>
                                <Border Background="{StaticResource BorderDark}" CornerRadius="4" Width="24" Height="24">
                                    <TextBlock Text="+" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <Border Grid.Column="4" Background="{StaticResource BorderDark}" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="UNIT" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            </Border>
                            <TextBlock Grid.Column="5" Text="$24.99" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="2" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10" Padding="20,15">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Border Style="{StaticResource KeycapStyle}">
                                    <TextBlock Text="DEL" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="REMOVE ITEM" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                                <Border Style="{StaticResource KeycapStyle}" Background="{StaticResource AccentRed}">
                                    <TextBlock Text="F6" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="EDIT QUANTITY" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="TOTAL ITEMS: 4" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Background="{StaticResource PanelDark}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="🛒 ORDER SUMMARY" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" Margin="0,0,0,30"/>

                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Subtotal" Foreground="{StaticResource TextSecondary}" FontSize="16"/>
                            <TextBlock Text="$422.98" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Tax (8%)" Foreground="{StaticResource TextSecondary}" FontSize="16"/>
                            <TextBlock Text="$33.84" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,30">
                            <TextBlock Text="Discount [F7]" Foreground="{StaticResource AccentRed}" FontSize="16"/>
                            <TextBlock Text="-$0.00" Foreground="{StaticResource AccentRed}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Separator Background="{StaticResource BorderDark}" Margin="0,0,0,20"/>

                        <TextBlock Text="TOTAL AMOUNT" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="12"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,0">
                            <TextBlock Text="$456" Foreground="{StaticResource TextPrimary}" FontSize="54" FontWeight="Bold"/>
                            <TextBlock Text=".82" Foreground="{StaticResource AccentRed}" FontSize="54" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource AccentRed}" CornerRadius="10" Padding="25" Margin="0,20,0,0">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="PROCEED TO" Foreground="#FFD6DA" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="PAYMENT" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border Background="#40FFFFFF" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" Margin="0,0,0,10">
                                <TextBlock Text="ENTER" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="💵" FontSize="24" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="Transparent" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="10" Padding="20" Margin="0,20,0,0">
                    <TextBlock Text="🖨️ PRINT RECENT [F12]" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border Style="{StaticResource KeycapStyle}">
                    <TextBlock Text="F1" Foreground="{StaticResource AccentRed}" FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="NEW" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="11" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <Border Style="{StaticResource KeycapStyle}">
                    <TextBlock Text="F2" Foreground="{StaticResource AccentRed}" FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="SEARCH" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="11" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <Border Style="{StaticResource KeycapStyle}">
                    <TextBlock Text="F5" Foreground="{StaticResource AccentRed}" FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="CLEAR" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="11" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <Border Style="{StaticResource KeycapStyle}">
                    <TextBlock Text="F7" Foreground="{StaticResource AccentRed}" FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="DISCOUNT" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="11" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <Border Style="{StaticResource KeycapStyle}">
                    <TextBlock Text="F8" Foreground="{StaticResource AccentRed}" FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="CHECKOUT" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="📶 STABLE" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="11" Margin="0,0,20,0" VerticalAlignment="Center"/>
                <TextBlock Text="🕒 14:22:08" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>