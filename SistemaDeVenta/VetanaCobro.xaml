<Window x:Class="SistemaDeVenta.VetanaCobrousuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ModernPOS v2.4" Height="900" Width="1300"
        Background="#0B0F14" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowState="Maximized" KeyDown="Window_KeyDown">
    

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark"        Color="#0B0F14"/>
        <SolidColorBrush x:Key="PanelDark"     Color="#141A22"/>
        <SolidColorBrush x:Key="BorderDark"    Color="#2B3442"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#4A90E2"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8A94A6"/>

        <Style x:Key="KeycapStyle" TargetType="Border">
            <Setter Property="Background"   Value="#2B3442"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding"      Value="6,2"/>
            <Setter Property="Margin"       Value="0,0,8,0"/>
        </Style>

        <Style x:Key="CustomDataGridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="0,10">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,1,0,1"/>
            <Setter Property="Margin"          Value="0,0,0,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0AFFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"  Value="#204A90E2"/>
                    <Setter Property="BorderBrush" Value="#4A90E2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="10,0,10,15"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border Background="{StaticResource AccentRed}" Width="30" Height="20"
                        CornerRadius="4" Margin="0,0,10,0">
                    <TextBlock Text="▶" Foreground="White"
                               VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                </Border>
                <TextBlock Text="ModernPOS" Foreground="{StaticResource TextPrimary}"
                           FontSize="24" FontWeight="Bold"/>
                <TextBlock Text=" v2.4" Foreground="{StaticResource TextSecondary}"
                           FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="ALEX RODRIGUEZ"
                               Foreground="{StaticResource TextPrimary}"
                               FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                </StackPanel>
                <Ellipse Width="40" Height="40" Fill="#2B3442" Margin="0,0,20,0"/>
                <Border BorderBrush="{StaticResource AccentRed}" BorderThickness="1"
                        Background="#204A90E2" CornerRadius="8" Padding="15,8" MouseDown="Border_MouseDown_2">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource AccentRed}"
                                CornerRadius="4" Padding="4,1" Margin="0,0,8,0">
                            <TextBlock Text="ESC" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="LOGOUT ➔" Foreground="White"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ROW 1: Barra de búsqueda -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <Border BorderBrush="{StaticResource AccentRed}" BorderThickness="1"
                    CornerRadius="10" Background="{StaticResource PanelDark}" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="PanelQty"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="Collapsed"
                                Margin="0,0,10,0">
                        <TextBlock Text="|||" Foreground="{StaticResource AccentRed}"
                                   FontWeight="Bold" FontSize="20" Margin="0,0,10,0">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                        <TextBlock Text="QTY:" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <Border Background="#334A90E2" CornerRadius="4" Padding="6,2">
                            <TextBlock x:Name="TxtQty" Text="1"
                                       Foreground="{StaticResource AccentRed}" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <TextBox x:Name="TxtBusqueda"
                             Grid.Column="1"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             FontSize="16"
                             VerticalContentAlignment="Center"
                             KeyDown="TxtBusqueda_KeyDown"
                             PreviewTextInput="TxtBusqueda_PreviewTextInput"/>

                    <TextBlock IsHitTestVisible="False"
                               Text="Escriba el producto o presione [F2] para buscar..."
                               VerticalAlignment="Center"
                               Foreground="#505A6B"
                               FontSize="16"
                               FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtBusqueda}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Visibility, ElementName=PanelQty}" Value="Visible">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource AccentRed}" CornerRadius="8"
                                Padding="20,10" MouseDown="Border_MouseDown">
                            <TextBlock Text="+ ADD ITEM" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- ROW 2: Tabla + Panel derecho -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Tabla -->
            <Border Grid.Column="0" Background="{StaticResource PanelDark}"
                    BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                    CornerRadius="10" Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="GridProductos" Grid.Row="0" Margin="10,20"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderThickness="0"
                              RowStyle="{StaticResource CustomDataGridRow}"
                              CellStyle="{StaticResource CustomDataGridCell}"
                              ColumnHeaderStyle="{StaticResource CustomDataGridColumnHeader}">
                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header="ID" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Id}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center" Margin="15,0,0,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="DESCRIPTION" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontWeight="Bold" FontSize="15"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="11" Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="UNIT PRICE" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding UnitPrice, StringFormat=C}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontWeight="Bold" FontSize="15"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="QTY [F6]" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Button Content="-" Width="26" Height="26"
                                                    Background="{StaticResource BorderDark}"
                                                    Foreground="White" BorderThickness="0"/>
                                            <Border Background="{StaticResource BgDark}"
                                                    CornerRadius="4" Margin="10,0" Padding="12,4">
                                                <TextBlock Text="{Binding Quantity}"
                                                           Foreground="White" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Button Content="+" Width="26" Height="26"
                                                    Background="{StaticResource BorderDark}"
                                                    Foreground="White" BorderThickness="0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="UNIT" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BorderDark}"
                                                CornerRadius="4" Padding="8,4"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Unit}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="TOTAL" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Total, StringFormat=C}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontWeight="Bold" FontSize="15"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" Margin="0,0,15,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Footer tabla -->
                    <Border Grid.Row="1" Background="{StaticResource BgDark}"
                            CornerRadius="0,0,10,10" Padding="20,15">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Border Style="{StaticResource KeycapStyle}">
                                    <TextBlock Text="DEL" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="REMOVE ITEM"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <Border Style="{StaticResource KeycapStyle}"
                                        Background="{StaticResource AccentRed}">
                                    <TextBlock Text="F6" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="EDIT QUANTITY"
                                           Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtTotalItems"
                                       Text="TOTAL ITEMS: 0"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Panel derecho: resumen + botón abajo -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Order Summary -->
                <Border Grid.Row="0" Background="{StaticResource PanelDark}"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1" CornerRadius="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="🛒 ORDER SUMMARY"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontWeight="Bold" Margin="0,0,0,30"/>

                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Subtotal"
                                       Foreground="{StaticResource TextSecondary}" FontSize="16"/>
                            <TextBlock x:Name="TxtSubtotal"
                                       Text="$0.00"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,30">
                            <TextBlock Text="Tax (8%)"
                                       Foreground="{StaticResource TextSecondary}" FontSize="16"/>
                            <TextBlock x:Name="TxtTax"
                                       Text="$0.00"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Separator Background="{StaticResource BorderDark}" Margin="0,0,0,20"/>
                        <TextBlock Text="TOTAL AMOUNT"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontWeight="Bold" FontSize="12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock x:Name="TxtTotalEntero"
                                       Text="$0"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="54" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTotalDecimal"
                                       Text=".00"
                                       Foreground="{StaticResource AccentRed}"
                                       FontSize="54" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Botón pegado al fondo -->
                <Border Grid.Row="1"
                        Background="{StaticResource AccentRed}"
                        CornerRadius="10" Padding="25"
                        Margin="0,20,0,0"
                        VerticalAlignment="Bottom" MouseDown="Border_MouseDown_1">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="PROCEED TO" Foreground="#CCE0F5"
                                       FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="PAYMENT" Foreground="White"
                                       FontSize="28" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock Text="💵" FontSize="30"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ROW 3: Barra inferior -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Border Style="{StaticResource KeycapStyle}">
                    <TextBlock Text="F1" Foreground="{StaticResource AccentRed}"
                               FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="NEW" Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="0,0,15,0" VerticalAlignment="Center" FontWeight="Bold"/>
                <Border Style="{StaticResource KeycapStyle}">
                    <TextBlock Text="F2" Foreground="{StaticResource AccentRed}"
                               FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="SEARCH" Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="0,0,15,0" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>